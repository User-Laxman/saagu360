rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- User Specific Rules ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /disease_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /eligibility_checks/{checkId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- Global Schemes Cache ---
    match /schemes_cache/{docId} {
      allow read: if true; // Publicly readable
      allow write: if false; // Only via Admin/Service (Simulated here)
    }

    // --- Market Prices ---
    match /market_prices/{commodity} {
      allow read: if true; // Publicly readable
      allow write: if false; // Only via backend service
    }

    // --- API Logs ---
    match /api_logs/{logId} {
      allow create: if request.auth != null; // Registered users can log
      allow read: if false; // Users cannot read logs
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
